{
    "manifest_version": 3,
    "name": "DOMDiff",
    "version": "1.0.0",
    "description": "Compare visual and DOM differences between two webpages.",
    "action": {
        "default_title": "Open DOMDiff"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "permissions": [
        "activeTab",
        "tabs"
    ]
}